{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "app/api/inngest/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/daily-scan",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/sms-drip",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/skip-trace",
      "schedule": "0 17 * * *"
    }
  ]
}
