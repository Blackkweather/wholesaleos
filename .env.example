# ════════════════════════════════════════════════════════════════════════════
# WholesaleOS — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ════════════════════════════════════════════════════════════════════════════

# ── Database (Postgres) ─────────────────────────────────────────────────────
# Local (pgAdmin4 default):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wholesaleos?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/wholesaleos?schema=public"
# Supabase: use the pooled URL for DATABASE_URL and the direct URL for DIRECT_URL.

# ── AI Gateway (PRIMARY — Phase 0) ──────────────────────────────────────────
# Unified multi-model transport with failover: Gemini 2.5 Flash -> Llama 3.3 70B
# (Groq) -> GPT-4o-mini. Set the gateway key (OpenRouter or Vercel AI Gateway).
AI_GATEWAY_URL=""                      # blank = OpenRouter default
AI_GATEWAY_KEY=""                      # or set OPENROUTER_API_KEY below
OPENROUTER_API_KEY=""
AI_PRIMARY_MODEL="google/gemini-2.5-flash"
AI_FALLBACK_MODEL="llama-3.3-70b-versatile"   # used via direct Groq
AI_EMERGENCY_MODEL="openai/gpt-4o-mini"
GROQ_API_KEY=""                        # enables the fallback tier (direct Groq)

# ── Legacy AI keys (optional fallbacks) ─────────────────────────────────────
# Anthropic (paid, used by lib/claude when set); Gemini AI Studio (free).
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""

# ── Inngest (event bus + durable workers — Phase 0/4/5) ─────────────────────
# Create an app at https://inngest.com, then paste the keys.
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ── Data + research APIs ────────────────────────────────────────────────────
TAVILY_API_KEY=""                      # web search for the agent
RENTCAST_API_KEY=""                    # ARV/comps — FREE tier 50/mo (quota-guarded)

# ── Reliability (Phase 2) — daily spend caps in CENTS + admin secret ────────
CAP_AI_CENTS="2000"
CAP_SMS_CENTS="5000"
CAP_MAIL_CENTS="10000"
CAP_DATA_CENTS="1000"
CAP_EMAIL_CENTS="500"
# Bearer secret for /api/admin/* (killswitch, spend, deadletter). openssl rand -hex 24
KILLSWITCH_SECRET="change-me-random-hex"

# ── Auth Gate ───────────────────────────────────────────────────────────────
# Password to access the app. Leave blank to disable the gate (local dev only).
APP_PASSWORD="wholesale2026"

# ── NextAuth (session signing) ──────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional — not used in single-user mode)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Email (Resend) — optional ────────────────────────────────────────────────
# For AI briefing emails. Get a free key at: https://resend.com
RESEND_API_KEY=""
EMAIL_FROM="WholesaleOS <onboarding@resend.dev>"

# ── Redis (Upstash) — RECOMMENDED for production ────────────────────────────
# Backs rate-limiting AND the reliability/compliance/surfacing layers (spend
# caps, killswitch, circuit breakers, DNC, adaptive threshold). Falls back to
# per-instance memory when unset — fine for dev, but caps/killswitch won't hold
# across serverless instances in production. Get a free DB at https://upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Encryption ──────────────────────────────────────────────────────────────
# Used to encrypt Twilio credentials stored in DB. Must be 32+ chars.
# Generate: openssl rand -base64 32
ENCRYPTION_KEY="change-me-to-32-plus-chars-random-string"

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Secret for cron endpoints (/api/cron/*). Sent as Bearer token.
# Generate: openssl rand -hex 16
CRON_SECRET="change-me-random-hex"
